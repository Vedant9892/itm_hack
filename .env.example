# BACKEND CONFIGURATION
# Place this mapped correctly in backend/.env

# Supabase Authentication & Database Configuration
SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"
SUPABASE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# AI Inference Layer
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# Server Port Definition
PORT=5000

# Google Fit Web Authentication
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLOUD_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLOUD_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="http://localhost:5000/api/auth/google/callback"

# MongoDB Connectivity
MONGO_URI="mongodb://127.0.0.1:27017/itm_health"

# Permitted Client Origins
FRONTEND_URL="http://localhost:5173"

# Automation Webhooks
N8N_STRESS_WEBHOOK="http://localhost:5678/webhook/stress-calc"
N8N_SORENESS_WEBHOOK="http://localhost:5678/webhook/soreness-relief"

---

